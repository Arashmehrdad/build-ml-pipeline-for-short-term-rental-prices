name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_artifact:
        type: str
        description: Fully-qualified input artifact name, e.g. "sample.csv:latest"
      output_artifact:
        type: str
        description: Name for the cleaned output artifact
      output_type:
        type: str
        description: Artifact type for the cleaned dataset
      output_description:
        type: str
        description: Artifact description
      min_price:
        type: float
        description: Minimum nightly price to keep
      max_price:
        type: float
        description: Maximum nightly price to keep
    command: >
      python run.py
      --input_artifact {input_artifact}
      --output_artifact {output_artifact}
      --output_type {output_type}
      --output_description "{output_description}"
      --min_price {min_price}
      --max_price {max_price}
